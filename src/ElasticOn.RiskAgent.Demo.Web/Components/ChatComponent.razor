@using ElasticOn.RiskAgent.Demo.Web.Models
@using ElasticOn.RiskAgent.Demo.Web.Services
@using Microsoft.AspNetCore.Components
@inject HttpClient Http
@inject ChatStateService ChatState
@inject LocalizationService L
@implements IDisposable

<div class="chat-container">
    @if (messages.Count > 0)
    {
        <div class="chat-header">
            <button class="new-chat-button" @onclick="ResetChat" title="@L["ChatNewChat"]">
                <span class="new-chat-icon">✏️</span>
                <span class="new-chat-text">@L["ChatNewChat"]</span>
            </button>
        </div>
    }
    <div class="chat-messages" @ref="messagesContainer">
        @if (messages.Count == 0)
        {
            <div class="welcome-message">
                <h2>@L["WelcomeTitle"]</h2>
                <p>@(IsInternal ? L["WelcomeMessageInternal"] : L["WelcomeMessage"])</p>
            </div>
        }
        else
        {
            @foreach (var message in messages)
            {
                <div class="message @message.Role">
                    <div class="message-content">
                        @if (message.IsThinking)
                        {
                            <div class="thinking-indicator">
                                <span class="dot"></span>
                                <span class="dot"></span>
                                <span class="dot"></span>
                            </div>
                        }
                        else if (message.Role == "assistant")
                        {
                            @((MarkupString)message.Content)
                        }
                        else
                        {
                            @message.Content
                        }
                    </div>
                    <div class="message-time">@message.Timestamp.ToLocalTime().ToString("h:mm tt")</div>
                </div>
            }
        }
    </div>

    <div class="chat-input-container">
        <div class="content-safety-selector">
            <label for="contentSafetyMode">@L["ChatContentSafety"]</label>
            <select id="contentSafetyMode" @bind="selectedContentSafetyMode" disabled="@isProcessing">
                <option value="Disabled">@L["ChatContentSafetyDisabled"]</option>
                <option value="Audit">@L["ChatContentSafetyAudit"]</option>
                <option value="Enforce">@L["ChatContentSafetyEnforce"]</option>
            </select>
        </div>
        
        <div class="input-wrapper">
            <input type="text" 
                   class="chat-input" 
                   placeholder="@L["ChatPlaceholder"]"
                   @bind="currentMessage"
                   @bind:event="oninput"
                   @onkeypress="HandleKeyPress"
                   disabled="@(isProcessing || (IsInternal && string.IsNullOrEmpty(AgentName)))" />
            <button class="send-button" 
                    @onclick="SendMessage" 
                    disabled="@(isProcessing || string.IsNullOrWhiteSpace(currentMessage) || (IsInternal && string.IsNullOrEmpty(AgentName)))">
                @if (isProcessing)
                {
                    <span class="spinner"></span>
                }
                else
                {
                    <span>@L["ChatSend"]</span>
                }
            </button>
        </div>
        
        @if (IsInternal && string.IsNullOrEmpty(AgentName))
        {
            <div class="index-required-notice">
                <span>⚠️ @L["AgentConfigRequired"]</span>
            </div>
        }

        @if (!IsInternal && messages.Count == 0)
        {
            <div class="sample-prompts">
                <span class="prompts-label">@L["ChatTryAsking"]</span>
                @foreach (var promptKey in samplePromptKeys)
                {
                    var promptText = L[promptKey];
                    <button class="prompt-button" @onclick="() => SelectPrompt(promptText)">
                        @(promptText.Length > 50 ? promptText.Substring(0, 50) + "..." : promptText)
                    </button>
                }
            </div>
        }
    </div>
</div>

@code {
    /// <summary>Whether this instance is displayed on the Internal page (no sample prompts, requires agent config).</summary>
    [Parameter] public bool IsInternal { get; set; } = false;

    /// <summary>Agent name for the Internal page dynamic agent.</summary>
    [Parameter] public string? AgentName { get; set; }

    /// <summary>Agent instructions for the Internal page dynamic agent.</summary>
    [Parameter] public string? AgentInstructions { get; set; }

    /// <summary>Comma-delimited MCP tool names for the Internal page dynamic agent.</summary>
    [Parameter] public string? AgentTools { get; set; }

    private List<ChatMessage> messages = new();
    private string currentMessage = string.Empty;
    private bool isProcessing = false;
    private ElementReference messagesContainer;
    private string selectedContentSafetyMode = "Disabled";

    private readonly string[] samplePromptKeys = new[]
    {
        "SamplePrompt1",
        "SamplePrompt2",
        "SamplePrompt3",
        "SamplePrompt4",
        "SamplePrompt5",
        "SamplePromptJailbreak"
    };

    protected override void OnInitialized()
    {
        // Initialize conversation state on page load
        var conversationId = ChatState.ConversationId;
        L.OnLanguageChanged += OnLanguageChanged;
    }

    private void OnLanguageChanged()
    {
        InvokeAsync(StateHasChanged);
    }

    public void Dispose()
    {
        L.OnLanguageChanged -= OnLanguageChanged;
    }

    private void ResetChat()
    {
        messages.Clear();
        currentMessage = string.Empty;
        ChatState.ResetConversation();
        StateHasChanged();
    }

    private void SelectPrompt(string prompt)
    {
        currentMessage = prompt;
        StateHasChanged();
    }

    private async Task HandleKeyPress(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !isProcessing && !string.IsNullOrWhiteSpace(currentMessage))
        {
            await SendMessage();
        }
    }

    private async Task SendMessage()
    {
        if (string.IsNullOrWhiteSpace(currentMessage) || isProcessing)
            return;

        var userMessage = currentMessage.Trim();
        currentMessage = string.Empty;
        isProcessing = true;

        messages.Add(new ChatMessage
        {
            Role = "user",
            Content = userMessage,
            Timestamp = DateTime.UtcNow
        });

        var thinkingMessage = new ChatMessage
        {
            Role = "assistant",
            Content = L["ChatThinking"],
            IsThinking = true,
            Timestamp = DateTime.UtcNow
        };
        messages.Add(thinkingMessage);

        StateHasChanged();
        await ScrollToBottom();

        try
        {
            var request = new SendMessageRequest
            {
                Message = userMessage,
                ConversationId = ChatState.ConversationId,
                ThreadId = ChatState.ThreadId,
                ContentSafetyMode = selectedContentSafetyMode,
                AgentName = AgentName,
                AgentInstructions = AgentInstructions,
                AgentTools = AgentTools
            };

            var response = await Http.PostAsJsonAsync("/api/chat", request);

            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<SendMessageResponse>();

                if (result != null && result.Success)
                {
                    if (string.IsNullOrEmpty(ChatState.ThreadId) && !string.IsNullOrEmpty(result.ThreadId))
                    {
                        ChatState.ThreadId = result.ThreadId;
                    }

                    messages.Remove(thinkingMessage);
                    messages.Add(new ChatMessage
                    {
                        Role = "assistant",
                        Content = result.MessageHtml,
                        Timestamp = DateTime.UtcNow
                    });
                }
                else
                {
                    messages.Remove(thinkingMessage);
                    messages.Add(new ChatMessage
                    {
                        Role = "assistant",
                        Content = $"{L["ChatErrorPrefix"]} {result?.Error ?? L["ChatErrorUnknown"]}",
                        Timestamp = DateTime.UtcNow
                    });
                }
            }
            else
            {
                messages.Remove(thinkingMessage);
                messages.Add(new ChatMessage
                {
                    Role = "assistant",
                    Content = $"{L["ChatErrorPrefix"]} {L["ChatErrorConnection"]} {response.StatusCode}",
                    Timestamp = DateTime.UtcNow
                });
            }
        }
        catch (Exception ex)
        {
            messages.Remove(thinkingMessage);
            messages.Add(new ChatMessage
            {
                Role = "assistant",
                Content = $"{L["ChatErrorPrefix"]} {ex.Message}",
                Timestamp = DateTime.UtcNow
            });
        }
        finally
        {
            isProcessing = false;
            StateHasChanged();
            await ScrollToBottom();
        }
    }

    private async Task ScrollToBottom()
    {
        await Task.Delay(100);
    }
}
